# LLM provider for the agent + classify (provider-agnostic via llm_providers).
# Pick one provider and set its key. If no key is set the LLM is disabled
# (the agent will "ask" the human; nothing secret is ever sent to it).
#
# LLM_PROVIDER selects the backend: openrouter (default) | openai | anthropic.
LLM_PROVIDER=openrouter

# OpenRouter (one key, any model). Use a VISION model for the agent.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o

# OpenAI direct (LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic direct (LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
